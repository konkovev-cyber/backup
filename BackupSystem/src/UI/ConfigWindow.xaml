<Window x:Class="BackupSystem.UI.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Настройки" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:EqualsConverter x:Key="EqualsConverter" xmlns:local="clr-namespace:BackupSystem.UI"/>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TabControl materialDesign:ColorZoneAssist.Background="{DynamicResource PrimaryHueMidBrush}">
            <TabItem Header="Источники">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Button Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left"
                            Margin="0,0,0,8" Click="AddSource_Click"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Margin="0,0,8,0"/>
                            <TextBlock Text="Добавить"/>
                        </StackPanel>
                    </Button>
                    
                    <ListBox Grid.Row="1" Grid.Column="0" x:Name="SourcesListBox">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Padding="4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ScrollViewer Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="16,0,0,0"
                                  DataContext="{Binding SelectedItem, ElementName=SourcesListBox}">
                        <StackPanel>
                            <TextBlock Text="Настройки источника" Style="{DynamicResource MaterialDesignTitleLarge}" Margin="0,0,0,16"/>
                            <TextBlock Text="Название" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="Тип" FontWeight="Bold" Margin="0,0,0,4"/>
                            <ComboBox SelectedValue="{Binding Type}" SelectedValuePath="Content" Margin="0,0,0,16">
                                <ComboBoxItem Content="File"/>
                                <ComboBoxItem Content="OneS"/>
                                <ComboBoxItem Content="SqlServer"/>
                            </ComboBox>

                            <Separator Margin="0,0,0,16"/>

                            <!-- File Settings -->
                            <StackPanel Visibility="{Binding Type, Converter={StaticResource EqualsConverter}, ConverterParameter=File}">
                                <TextBlock Text="Пути (через ;)" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings[paths]}" Margin="0,0,0,8" materialDesign:HintAssist.Hint="C:\Data;D:\Work"/>
                                <TextBlock Text="Фильтры включения" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings[includeFilters]}" Margin="0,0,0,8" materialDesign:HintAssist.Hint="*.doc;*.xls"/>
                            </StackPanel>

                            <!-- SQL Server Settings -->
                            <StackPanel Visibility="{Binding Type, Converter={StaticResource EqualsConverter}, ConverterParameter=SqlServer}">
                                <TextBlock Text="Сервер" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings[server]}" Margin="0,0,0,8"/>
                                <TextBlock Text="База данных" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings[database]}" Margin="0,0,0,8"/>
                                <CheckBox Content="Integrated Security" IsChecked="{Binding Settings[useIntegratedSecurity]}" Margin="0,0,0,8"/>
                            </StackPanel>

                            <!-- 1C Settings -->
                            <StackPanel Visibility="{Binding Type, Converter={StaticResource EqualsConverter}, ConverterParameter=OneS}">
                                <TextBlock Text="Путь к базе/строка" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings[ibPath]}" Margin="0,0,0,8"/>
                                <TextBlock Text="Тип базы" FontWeight="Bold" Margin="0,0,0,4"/>
                                <ComboBox SelectedValue="{Binding Settings[dbType]}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="file"/>
                                    <ComboBoxItem Content="sql"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            
            <TabItem Header="Хранилища">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Button Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left"
                            Margin="0,0,0,8" Click="AddDestination_Click"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Margin="0,0,8,0"/>
                            <TextBlock Text="Добавить"/>
                        </StackPanel>
                    </Button>
                    
                    <ListBox Grid.Row="1" Grid.Column="0" x:Name="DestinationsListBox">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Padding="4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ScrollViewer Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="16,0,0,0"
                                  DataContext="{Binding SelectedItem, ElementName=DestinationsListBox}">
                        <StackPanel>
                            <TextBlock Text="Настройки хранилища" Style="{DynamicResource MaterialDesignTitleLarge}" Margin="0,0,0,16"/>
                            <TextBlock Text="Название" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="Тип" FontWeight="Bold" Margin="0,0,0,4"/>
                            <ComboBox SelectedValue="{Binding Type}" SelectedValuePath="Content" Margin="0,0,0,16">
                                <ComboBoxItem Content="Local"/>
                                <ComboBoxItem Content="Ftp"/>
                                <ComboBoxItem Content="Network"/>
                            </ComboBox>

                            <Separator Margin="0,0,0,16"/>

                            <!-- Local Settings -->
                            <StackPanel Visibility="{Binding Type, Converter={StaticResource EqualsConverter}, ConverterParameter=Local}">
                                <TextBlock Text="Путь" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings[path]}" Margin="0,0,0,8"/>
                            </StackPanel>

                            <!-- Network Settings -->
                            <StackPanel Visibility="{Binding Type, Converter={StaticResource EqualsConverter}, ConverterParameter=Network}">
                                <TextBlock Text="UNC Путь" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings[uncPath]}" Margin="0,0,0,8" materialDesign:HintAssist.Hint="\\server\share"/>
                                <TextBlock Text="Пользователь" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings[username]}" Margin="0,0,0,8"/>
                            </StackPanel>

                            <!-- FTP Settings -->
                            <StackPanel Visibility="{Binding Type, Converter={StaticResource EqualsConverter}, ConverterParameter=Ftp}">
                                <TextBlock Text="Хост" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings[host]}" Margin="0,0,0,8"/>
                                <TextBlock Text="Порт" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings[port]}" Margin="0,0,0,8"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            
            <TabItem Header="Задачи">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Button Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left"
                            Margin="0,0,0,8" Click="AddJob_Click"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Margin="0,0,8,0"/>
                            <TextBlock Text="Добавить задачу"/>
                        </StackPanel>
                    </Button>
                    
                    <ListBox Grid.Row="1" Grid.Column="0" x:Name="JobsListBox">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Id}" FontSize="10" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ScrollViewer Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="16,0,0,0"
                                  DataContext="{Binding SelectedItem, ElementName=JobsListBox}">
                        <StackPanel>
                            <TextBlock Text="Параметры задачи" Style="{DynamicResource MaterialDesignTitleLarge}" Margin="0,0,0,16"/>
                            
                            <TextBlock Text="Название задачи" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                            <Separator Margin="0,8,0,16"/>
                            
                            <TextBlock Text="Архивирование" Style="{DynamicResource MaterialDesignTitleMedium}" FontWeight="Bold" Margin="0,0,0,8"/>
                            <CheckBox Content="Включить сжатие (ZIP)" IsChecked="{Binding Archiver.Enabled}" Margin="0,0,0,8"/>
                            <CheckBox Content="Удалять исходный файл после сжатия" IsChecked="{Binding Archiver.DeleteSourceAfterArchive}" Margin="0,0,0,16"/>

                            <Separator Margin="0,8,0,16"/>

                            <TextBlock Text="Политика хранения (Retention)" Style="{DynamicResource MaterialDesignTitleMedium}" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Укажите, сколько копий нужно хранить:" Style="{StaticResource HintText}"/>
                            
                            <Grid Margin="0,8,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Ежедневно" FontSize="11" Opacity="0.7"/>
                                    <TextBox Text="{Binding Retention.KeepDaily}" materialDesign:HintAssist.Hint="Дней"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                    <TextBlock Text="Еженедельно" FontSize="11" Opacity="0.7"/>
                                    <TextBox Text="{Binding Retention.KeepWeekly}" materialDesign:HintAssist.Hint="Недель"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                    <TextBlock Text="Ежемесячно" FontSize="11" Opacity="0.7"/>
                                    <TextBox Text="{Binding Retention.KeepMonthly}" materialDesign:HintAssist.Hint="Месяцев"/>
                                </StackPanel>
                            </Grid>
                            
                            <TextBlock Text="* Старые копии будут удаляться автоматически." Style="{StaticResource HintText}" Foreground="Orange"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            
            <TabItem Header="Общие">
                <ScrollViewer Margin="16">
                    <StackPanel>
                        <TextBlock Text="Папка для временных файлов" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox x:Name="TempPathTextBox" Margin="0,0,0,16"/>
                        
                        <TextBlock Text="Уровень логирования" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="LogLevelComboBox" Margin="0,0,0,16">
                            <ComboBoxItem Content="Debug"/>
                            <ComboBoxItem Content="Info"/>
                            <ComboBoxItem Content="Warning"/>
                            <ComboBoxItem Content="Error"/>
                        </ComboBox>
                        
                        <TextBlock Text="Макс. одновременных задач" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox x:Name="MaxJobsTextBox" Margin="0,0,0,16"/>
                        
                        <TextBlock Text="Таймаут операций (мин)" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox x:Name="TimeoutTextBox" Margin="0,0,0,16"/>
                        
                        <TextBlock Text="Попыток при ошибке" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox x:Name="RetryCountTextBox" Margin="0,0,0,16"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="SaveButton" Click="SaveButton_Click"
                    Style="{DynamicResource MaterialDesignRaisedSecondaryButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,8,0"/>
                    <TextBlock Text="Сохранить"/>
                </StackPanel>
            </Button>
            <Button x:Name="CancelButton" Click="CancelButton_Click"
                    Style="{DynamicResource MaterialDesignFlatButton}">
                <TextBlock Text="Отмена"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
